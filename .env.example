# Copy this file to .env and fill in your values
# Never commit .env to version control

PORT=3000

# Get a free key at https://open-meteo.com/en/docs 
OPENMETEO_API_LINK=https://api.open-meteo.com/v1/forecast?latitude=45.8144&longitude=15.978&daily=temperature_2m_max,temperature_2m_min,uv_index_max&hourly=temperature_2m,relative_humidity_2m,wind_speed_10m,precipitation,precipitation_probability&current=temperature_2m,wind_speed_10m,wind_gusts_10m,relative_humidity_2m&forecast_days=3

# Comma-separated list of RSS feed URLs
NEWS_RSS_URLS=https://feeds.bbci.co.uk/news/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml
NEWS_MAX_ITEMS=8

# Cache durations in milliseconds
CACHE_WEATHER_TTL_MS=600000
CACHE_NEWS_TTL_MS=300000

# GitHub personal access token (generate at https://github.com/settings/tokens)
GITHUB_TOKEN=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
